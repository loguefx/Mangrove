# Mangrove environment configuration (spec §12). Copy to `.env` and fill in real values.
# NEVER commit the real .env file.

# HTTP port the API binds to (default 5000).
MANGROVE_PORT=5000

# Absolute path to the SQLite database file (created on first run).
MANGROVE_DB_PATH=./apps/server/mangrove.db

# Directory for the cover/thumbnail cache.
MANGROVE_CACHE_DIR=./apps/server/cache

# 32-byte key (base64) used to encrypt SMB credentials at rest (AES-256-GCM).
# Generate one with:  openssl rand -base64 32
MANGROVE_DATAPROTECTION_KEY=

# Secret used to sign JWT access tokens. Use a long random string.
# Generate one with:  openssl rand -base64 48
MANGROVE_JWT_SECRET=

# Optional SMTP settings (password reset / send-to-Kindle) — unused in Phase 1.
# MANGROVE_SMTP_HOST=
# MANGROVE_SMTP_PORT=
# MANGROVE_SMTP_USER=
# MANGROVE_SMTP_PASS=
